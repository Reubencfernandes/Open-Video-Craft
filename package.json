{
  "name": "open-video-craft",
  "version": "2.2.1",
  "description": "Build Tech Demo Videos",
  "private": true,
  "license": "ISC",
  "author": "Reuben Chagas Fernandes",
  "productName": "Open Video Craft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reubencfernandes/Open-Video-Craft.git"
  },
  "type": "commonjs",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main/main.js\"",
    "build:icons": "node scripts/create-app-icons.mjs",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build:icons && npm run build && electron-builder",
    "dist:win": "npm run build:icons && npm run build && electron-builder --win",
    "dist:mac": "node scripts/check-mac-signing.mjs && npm run build:icons && npm run build && electron-builder --mac",
    "verify:mac-release": "node scripts/verify-mac-release.mjs",
    "dist:mac:adhoc": "npm run build:icons && npm run build && electron-builder --mac -c.mac.identity=-",
    "dist:mac:universal": "node scripts/check-mac-signing.mjs && npm run build:icons && npm run build && electron-builder --mac --universal",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "test:mcp": "npm run build:main && node scripts/test-mcp-smoke.mjs",
    "start": "electron dist-electron/main/main.js"
  },
  "build": {
    "appId": "com.openvideocraft.app",
    "productName": "Open Video Craft",
    "copyright": "Copyright (c) 2026 Reuben Chagas Fernandes",
    "asar": true,
    "electronFuses": {
      "runAsNode": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "buildResources": "build",
      "output": "release/${version}"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json",
      "!node_modules/sharp/**/*",
      "!node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": "src/renderer/assets/app.png",
        "to": "app.png"
      },
      {
        "from": "resources/acestep_generate.py",
        "to": "acestep_generate.py"
      }
    ],
    "artifactName": "Open-Video-Craft-${version}-${os}-${arch}.${ext}",
    "mac": {
      "icon": "build/icon.icns",
      "forceCodeSigning": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "category": "public.app-category.video",
      "extendInfo": {
        "CFBundleDisplayName": "Open Video Craft",
        "CFBundleName": "Open Video Craft",
        "LSApplicationCategoryType": "public.app-category.video",
        "NSCameraUsageDescription": "Open Video Craft uses the camera when recording face camera video.",
        "NSMicrophoneUsageDescription": "Open Video Craft uses the microphone when recording audio.",
        "NSScreenCaptureDescription": "Open Video Craft records the selected screen or window."
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Open-Video-Craft-Setup-${version}-${os}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Open-Video-Craft-Portable-${version}-${os}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Reubencfernandes",
      "repo": "Open-Video-Craft"
    }
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "sharp": "^0.32.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wavesurfer.js": "^7.12.8",
    "zod": "^4.4.3"
  }
}
